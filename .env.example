DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_DATABASE_ENGINE=sqlite
SQLITE_PATH=local.sqlite3

# PostgreSQL (used when DJANGO_DATABASE_ENGINE=postgres or production settings)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hr_managemnt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=

REDIS_URL=redis://localhost:6379/0

# Railway / production toggles
DJANGO_USE_REDIS_CACHE=False
DJANGO_USE_S3_STORAGE=False
DJANGO_STATIC_URL=/static/
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/app/media
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

WEB_CONCURRENCY=1
GUNICORN_THREADS=2
DJANGO_SECURE_SSL_REDIRECT=False

# Production DB required
# DJANGO_SETTINGS_MODULE=config.settings.production
# DJANGO_DATABASE_ENGINE=postgres
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# NOTE: use `postgres` (not `postgress`)
