{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn config.wsgi --bind 0.0.0.0:${PORT:-8000} --log-file - --workers ${WEB_CONCURRENCY:-1} --threads ${GUNICORN_THREADS:-2} --timeout 120",
    "healthcheckPath": "/healthz/",
    "restartPolicyType": "ON_FAILURE"
  }
}
